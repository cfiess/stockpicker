# ============================================================
# Stock Screener — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit your .env file to version control.
# ============================================================

# ------ Twilio (required for SMS delivery) ------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+15550000000   # Your Twilio phone number
TWILIO_TO_NUMBER=+15551234567     # Your personal phone number

# ------ Alpaca (optional — used for real-time quotes) -------
# Sign up free at https://alpaca.markets
# Paper-trading keys work fine for market data.
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ------ App settings (optional overrides) -------------------
# Run timezone (should stay America/New_York for ET)
TZ=America/New_York

# Set to "true" to skip SMS and just print to stdout (useful for testing)
DRY_RUN=false

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
