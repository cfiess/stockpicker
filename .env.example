# ============================================================
# Stock Screener — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit your .env file to version control.
# ============================================================

# ------ Gmail (required for email delivery) -----------------
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Create an App Password:     https://myaccount.google.com/apppasswords
GMAIL_USER=your.address@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx   # 16-char App Password (spaces optional)

# ------ Alpaca (optional — used for real-time quotes) -------
# Sign up free at https://alpaca.markets
# Paper-trading keys work fine for market data.
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ------ App settings (optional overrides) -------------------
# Run timezone (should stay America/New_York for ET)
TZ=America/New_York

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
